{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open home.html (starts server on :8000)",
      "url": "http://127.0.0.1:8000/home.html",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start static server (port 8000)"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open home.html (server already running)",
      "url": "http://127.0.0.1:8000/home.html",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
