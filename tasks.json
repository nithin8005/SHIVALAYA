{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start static server (port 8000)",
      "type": "shell",
      "command": "python -m http.server 8000",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": {
        "owner": "http-server",
        "pattern": { "regexp": "^." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
